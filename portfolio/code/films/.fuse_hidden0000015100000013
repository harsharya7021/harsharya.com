<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script>
(function(){
  const $ = s => document.querySelector(s);
  let started = false;

  const tl = gsap.timeline({paused:true, onUpdate(){ $("#progress").style.width=(tl.progress()*100)+"%"; }});
  const showS = sel => [sel,{autoAlpha:1,duration:.001}];
  const hideS = sel => [sel,{autoAlpha:0,duration:.55,ease:"power2.inOut"}];
  const outAll = sel => [sel+" > *",{autoAlpha:0,y:-16,duration:.6,ease:"power2.in",stagger:.05}];
  const rise = (sel,pos,stag=0.15)=>tl.from(sel,{yPercent:115,duration:.95,ease:"power4.out",stagger:stag},pos);

  /* S1 · 0–8 */
  tl.to(...showS("#s1"));
  tl.from("#s1 .med",{autoAlpha:0,y:14,duration:.9,ease:"power3.out"},"+=0.3");
  rise("#s1 .line>span","+=0.6");
  tl.from("#s1c",{autoAlpha:0,duration:.8},"+=0.4");
  tl.to({},{duration:1.7}).to(...outAll("#s1")).to(...hideS("#s1"));

  /* S2 · 8–17 */
  tl.to(...showS("#s2"));
  tl.from("#s2 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from(".s2l",{autoAlpha:0,y:22,duration:.75,ease:"power3.out",stagger:.85},"+=0.2");
  tl.from("#s2s",{autoAlpha:0,duration:.8},"+=0.4");
  tl.to({},{duration:1.6}).to(...outAll("#s2")).to(...hideS("#s2"));

  /* S3 · 17–26 */
  tl.to(...showS("#s3"));
  rise("#s3 .line>span","+=0.2",.55);
  tl.from("#s3s",{autoAlpha:0,y:12,duration:.8},"+=0.5");
  tl.from("#s3wm",{autoAlpha:0,letterSpacing:".25em",duration:1,ease:"power2.out"},"+=0.3");
  tl.to({},{duration:2}).to(...outAll("#s3")).to(...hideS("#s3"));

  /* S4 · 26–35 */
  tl.to(...showS("#s4"));
  tl.from("#s4 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s4a",{autoAlpha:0,x:-44,duration:.85,ease:"power3.out"},"+=0.2");
  tl.from("#s4b",{autoAlpha:0,x:44,duration:.85,ease:"power3.out"},"-=0.65");
  tl.from("#s4x",{autoAlpha:0,scale:0,rotate:-90,duration:.7,ease:"back.out(2)"},"-=0.35");
  tl.to({},{duration:2.6}).to(...outAll("#s4")).to(...hideS("#s4"));

  /* S5 · 35–46 — Sunday session */
  tl.to(...showS("#s5"));
  tl.from("#s5 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s5 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s5card",{autoAlpha:0,y:44,duration:.9,ease:"power3.out"},"+=0.25");
  tl.from("#s5card .ch",{autoAlpha:0,y:12,duration:.45,ease:"power3.out",stagger:.22},"-=0.2");
  tl.to("#s5bar",{width:"64%",duration:2.4,ease:"power1.inOut"},"-=0.3");
  tl.from("#s5s",{autoAlpha:0,duration:.8},"-=1.6");
  tl.to({},{duration:1.2}).to(...outAll("#s5")).to(...hideS("#s5"));

  /* S6 · 46–58 — playable model performs */
  tl.to(...showS("#s6"));
  tl.from("#s6 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s6 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s6card",{autoAlpha:0,y:44,duration:.9,ease:"power3.out"},"+=0.25");
  tl.from("#s6s",{autoAlpha:0,duration:.7},"-=0.2");
  tl.call(()=>{ // scenario 2: C shut by PCB — opportunity cost vanishes
      $("#chipA").classList.remove("on"); $("#chipB").classList.add("on");
      $("#oppB").textContent="0";
      const b=$("#epB"); b.textContent="50"; b.className="big pos";
      gsap.fromTo("#s6card",{scale:1.012},{scale:1,duration:.4});
    },null,"+=1.6");
  tl.call(()=>{ // scenario 3: workers can't be fired — wages sunk
      $("#chipB").classList.remove("on"); $("#chipC").classList.add("on");
      $("#oppB").textContent="0"; $("#epB").textContent="100";
      $("#oppA").textContent="0";
      const a=$("#epA"); a.textContent="70"; a.className="big pos";
      gsap.fromTo("#s6card",{scale:1.012},{scale:1,duration:.4});
    },null,"+=2.2");
  tl.to({},{duration:2.4}).to(...outAll("#s6")).to(...hideS("#s6"));

  /* S7 · 58–69 — bloomburger counts down */
  const mpc={d:31};
  tl.to(...showS("#s7"));
  tl.from("#s7 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s7 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s7card",{autoAlpha:0,y:44,duration:.9,ease:"power3.out"},"+=0.25");
  tl.from("#s7card .dcell",{autoAlpha:0,y:16,duration:.5,ease:"power3.out",stagger:.25},"-=0.25");
  tl.to(mpc,{d:28,duration:1.8,ease:"steps(3)",onUpdate(){$("#mpcdays").textContent=Math.round(mpc.d);}},"-=0.4");
  tl.from("#s7s",{autoAlpha:0,duration:.8},"-=0.8");
  tl.to({},{duration:1.6}).to(...outAll("#s7")).to(...hideS("#s7"));

  /* S8 · 69–83 — BIL types, sighs first */
  const bilFull="*sigh* We covered this at IIM-A in week one — but fine. REER adjusts the rupee for inflation differentials against 40 partners. Below 100 means cheap in real terms: your imports feel pricey, your exporters quietly cheer.";
  const bilObj={n:0};
  tl.to(...showS("#s8"));
  tl.from("#s8 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s8 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s8card",{autoAlpha:0,y:44,duration:.9,ease:"power3.out"},"+=0.25");
  tl.from("#m1",{autoAlpha:0,y:14,duration:.5},"-=0.2");
  tl.set("#bilcite",{autoAlpha:0});
  tl.from("#m2",{autoAlpha:0,y:14,duration:.5},"+=0.6");
  tl.to(bilObj,{n:bilFull.length,duration:4.6,ease:"none",onUpdate(){$("#biltxt").textContent=bilFull.slice(0,Math.round(bilObj.n));}});
  tl.to("#bilcite",{autoAlpha:1,duration:.5},"+=0.2");
  tl.from("#s8s",{autoAlpha:0,duration:.8},"-=0.2");
  tl.to({},{duration:1.6}).to(...outAll("#s8")).to(...hideS("#s8"));

  /* S9 · 83–95 — DOS types */
  const dosCmd="dir", dosObj={n:0};
  tl.to(...showS("#s9"));
  tl.from("#s9 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s9 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s9card",{autoAlpha:0,y:44,duration:.9,ease:"power3.out"},"+=0.25");
  tl.to(dosObj,{n:dosCmd.length,duration:.7,ease:"steps(3)",onUpdate(){$("#dostype").textContent=dosCmd.slice(0,Math.round(dosObj.n));}},"+=0.5");
  tl.set("#dosout",{visibility:"visible",opacity:0},"+=0.3");
  tl.to("#dosout",{opacity:1,duration:.45});
  tl.from("#s9folders .folder",{autoAlpha:0,y:18,duration:.5,ease:"back.out(1.6)",stagger:.25},"+=0.4");
  tl.to("#doscur",{opacity:0,duration:.35,repeat:7,yoyo:true},"-=1.5");
  tl.to({},{duration:1.8}).to(...outAll("#s9")).to(...hideS("#s9"));

  /* S10 · 95–104 */
  tl.to(...showS("#s10"));
  tl.from("#s10 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s10a",{autoAlpha:0,x:-40,duration:.8,ease:"power3.out"},"+=0.2");
  tl.from("#s10b",{autoAlpha:0,x:40,duration:.8,ease:"power3.out"},"-=0.55");
  tl.to({},{duration:3.2}).to(...outAll("#s10")).to(...hideS("#s10"));

  /* S11 · 104–115 */
  tl.to(...showS("#s11"));
  tl.from("#s11 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s11 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s11 .srow",{autoAlpha:0,x:-30,duration:.5,ease:"power3.out",stagger:.38},"+=0.25");
  tl.to({},{duration:2}).to(...outAll("#s11")).to(...hideS("#s11"));

  /* S12 end */
  tl.to(...showS("#s12"));
  tl.from("#s12 .endmark",{autoAlpha:0,y:26,duration:1,ease:"power3.out"});
  tl.from("#s12a",{autoAlpha:0,y:12,duration:.7},"-=0.3");
  tl.from("#s12b",{autoAlpha:0,y:12,duration:.7},"-=0.35");
  tl.from("#replayBtn",{autoAlpha:0,duration:.8},"+=0.3");

  /* controls */
  function start(){ if(started) return; started=true;
    gsap.to("#poster",{autoAlpha:0,duration:.7,ease:"power2.inOut",onComplete(){$("#poster").style.visibility="hidden";}});
    gsap.to("#ctl",{opacity:1,duration:.6,delay:1});
    tl.play(0.001);
  }
  function replay(){ $("#paused").style.display="none"; tl.pause(0).play(0.001); }
  function togglePause(){ if(!started||tl.progress()===0) return;
    if(tl.paused()&&tl.progress()<0.999){ tl.play(); $("#paused").style.display="none"; }
    else if(!tl.paused()){ tl.pause(); $("#paused").style.display="flex"; } }
  function fullscreen(){ const el=document.documentElement;
    if(!document.fullscreenElement){(el.requestFullscreen||el.webkitRequestFullscreen||function(){}).call(el);}
    else{(document.exitFullscreen||document.webkitExitFullscreen||function(){}).call(document);} }

  $("#playBtn").addEventListener("click",e=>{e.stopPropagation();start();});
  $("#replayBtn").addEventListener("click",e=>{e.stopPropagation();replay();});
  $("#stage").addEventListener("click",()=>togglePause());
  document.addEventListener("keydown",e=>{
    if(e.code==="Space"){e.preventDefault(); started?togglePause():start();}
    if(e.key==="r"||e.key==="R"){if(started)replay();}
    if(e.key==="f"||e.key==="F"){fullscreen();}
  });

  /* QA: ?autoplay · ?t=SECONDS (paused) · &play */
  const qp=new URLSearchParams(location.search);
  if(qp.has("autoplay")||qp.has("t")){ start();
    if(qp.has("t")){ const t=Math.max(0.02,parseFloat(qp.get("t"))||0.02);
      qp.has("play") ? tl.play(t) : tl.pause(t); } }
})();
</script>
