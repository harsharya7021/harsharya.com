  <!-- S9 F6 research -->
  <section class="scene paper" id="s9">
    <div class="k">06 · And then it did something no school does</div>
    <div class="med" style="margin-top:2vh">It began <span class="navytxt it">studying itself.</span></div>
    <div class="bignums">
      <div class="bn"><b id="n1">0</b><span>RECORDED PARENT<br>INTERVIEWS</span></div>
      <div class="bn"><b id="n2">0</b><span>HOUSEHOLDS,<br>TWO FIELD WAVES</span></div>
      <div class="bn"><b id="n3">0</b><span>TEACHERS TRAINED AS<br>FIELD RESEARCHERS</span></div>
    </div>
    <div class="sub" id="s9s" style="margin-top:4vh;max-width:62ch">Interviews captured in the ERP, transcribed in Hindi and English, scored, coded — feeding segmentation, pricing, and the rebrand. <b style="color:var(--ink)">In a catchment of ~49 schools, nobody else has this.</b></div>
  </section>

  <!-- S10 the build -->
  <section class="scene navy" id="s10">
    <div class="k">Under the hood</div>
    <div class="med" style="margin-top:2vh">Institutional software, <span class="gold">headcount of one.</span></div>
    <div class="stackrows">
      <div class="srw"><span class="sn">01</span><span class="st">Django + DRF backend</span><span class="sd">14 modules · role-based access throughout</span></div>
      <div class="srw"><span class="sn">02</span><span class="st">Next.js web client</span><span class="sd">the office, the principal, the founders</span></div>
      <div class="srw"><span class="sn">03</span><span class="st">React Native staff app</span><span class="sd">full parity · first commit → pilot in ~5 weeks</span></div>
      <div class="srw"><span class="sn">04</span><span class="st">Self-hosted, dedicated cloud</span><span class="sd">owned infrastructure · nightly backups</span></div>
      <div class="srw"><span class="sn">05</span><span class="st">AI pipelines in production</span><span class="sd">OCR · transcription · NPS scoring · report cards</span></div>
    </div>
  </section>

  <!-- S11 end -->
  <section class="scene paper" id="s11">
    <div class="endmark">Diksha Public School.<br><span class="navytxt">Since 1998. Running on new rails.</span></div>
    <div class="endsub" id="s11a">The ledgers are retired. The school is not.</div>
    <div class="endsub" id="s11b" style="margin-top:1vh">Built by <b>Harsh Kumar Arya</b> · <b>harsharya.com</b></div>
    <button id="replayBtn">Replay ↻</button>
  </section>

  <div class="grain"></div>
  <div id="progress"></div>
  <div id="ctl">SPACE pause · R replay · F fullscreen</div>
  <div id="paused"><span>PAUSED — CLICK TO RESUME</span></div>

</div></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script>
(function(){
  const $=s=>document.querySelector(s);
  let started=false;
  const tl=gsap.timeline({paused:true,onUpdate(){$("#progress").style.width=(tl.progress()*100)+"%";}});
  const showS=s=>[s,{autoAlpha:1,duration:.001}];
  const hideS=s=>[s,{autoAlpha:0,duration:.55,ease:"power2.inOut"}];
  const outAll=s=>[s+" > *",{autoAlpha:0,y:-16,duration:.6,ease:"power2.in",stagger:.05}];
  const rise=(sel,pos,st=.15)=>tl.from(sel,{yPercent:115,duration:.95,ease:"power4.out",stagger:st},pos);

  /* S1 */
  tl.to(...showS("#s1"));
  rise("#s1 .med .line>span","+=0.3",.8);
  rise("#s1 .huge .line>span","+=0.6");
  tl.from("#s1c",{autoAlpha:0,duration:.7},"+=0.5");
  tl.to({},{duration:1.7}).to(...outAll("#s1")).to(...hideS("#s1"));

  /* S2 ledger — rows handwrite in, stamp slams */
  tl.to(...showS("#s2"));
  tl.from("#s2 .copy > *",{autoAlpha:0,y:16,duration:.7,ease:"power3.out",stagger:.18});
  tl.from("#sheet",{autoAlpha:0,y:44,rotate:1.5,duration:.9,ease:"power3.out"},"-=0.5");
  tl.from(".lr",{autoAlpha:0,x:-14,duration:.5,ease:"power2.out",stagger:.45},"+=0.2");
  tl.from("#stamp",{autoAlpha:0,scale:2.2,rotate:6,duration:.45,ease:"power4.in"},"+=0.4");
  tl.to({},{duration:1.6}).to(...outAll("#s2")).to(...hideS("#s2"));

  /* S3 title */
  tl.to(...showS("#s3"));
  tl.from("#s3k",{autoAlpha:0,letterSpacing:".6em",duration:.9,ease:"power2.out"});
  rise("#s3 .line>span","-=0.2",.5);
  tl.from("#s3s",{autoAlpha:0,duration:.8},"+=0.4");
  tl.to({},{duration:2}).to(...outAll("#s3")).to(...hideS("#s3"));

  /* S4 statements — values fill, counters run */
  const c={fy:0,f:0};
  tl.to(...showS("#s4"));
  tl.from("#s4 .copy > *",{autoAlpha:0,y:16,duration:.7,ease:"power3.out",stagger:.18});
  tl.from("#stmtcard",{autoAlpha:0,y:44,duration:.9,ease:"power3.out"},"-=0.5");
  [["#v1","✓ reconstructed"],["#v2","✓ categorised"],["#v3","✓ verified"],["#v4","visible, for the first time"]].forEach(([id,val],i)=>{
    tl.call(()=>{$(id).textContent=val;},null,"+="+(i?0.5:0.4));
    tl.from(id,{autoAlpha:0,duration:.3});
  });
  tl.to(c,{fy:4,f:475,duration:1.8,ease:"power2.out",onUpdate(){
    $("#cFY").textContent=Math.round(c.fy);$("#cF").textContent=Math.round(c.f);$("#cE").textContent="0";}},"+=0.3");
  tl.to({},{duration:1.5}).to(...outAll("#s4")).to(...hideS("#s4"));

  /* S5 dashboard — modules pop, cash lines land */
  tl.to(...showS("#s5"));
  tl.from("#s5 .copy > *",{autoAlpha:0,y:16,duration:.7,ease:"power3.out",stagger:.18});
  tl.from("#dashcard",{autoAlpha:0,y:44,duration:.9,ease:"power3.out"},"-=0.5");
  tl.from(".mod",{autoAlpha:0,scale:.65,duration:.35,ease:"back.out(1.8)",stagger:.09},"-=0.2");
  tl.from("#cash1",{autoAlpha:0,x:-20,duration:.5},"+=0.4");
  tl.from("#cash2",{autoAlpha:0,x:-20,duration:.5},"+=0.7");
  tl.to({},{duration:1.5}).to(...outAll("#s5")).to(...hideS("#s5"));

  /* S6 geofence — fence pulses, selfie ticks, status confirms */
  tl.to(...showS("#s6"));
  tl.from("#s6 .copy > *",{autoAlpha:0,y:16,duration:.7,ease:"power3.out",stagger:.18});
  tl.from("#s6phone",{autoAlpha:0,y:50,duration:.9,ease:"power3.out"},"-=0.5");
  tl.fromTo("#fence",{scale:1.5,opacity:0},{scale:1,opacity:.75,duration:1.1,ease:"power2.out"},"+=0.2");
  tl.from("#selfie",{autoAlpha:0,scale:.7,duration:.6,ease:"back.out(1.6)"},"+=0.3");
  tl.set("#tick",{visibility:"visible"});
  tl.from("#tick",{scale:0,duration:.45,ease:"back.out(2.5)"},"+=0.4");
  tl.call(()=>{$("#geostat").innerHTML="<b>CHECKED IN · 07:42</b><br>INSIDE SCHOOL BOUNDARY · SELFIE VERIFIED";});
  tl.to({},{duration:1.8}).to(...outAll("#s6")).to(...hideS("#s6"));

  /* S7 fees — receipt tears in */
  tl.to(...showS("#s7"));
  tl.from("#s7 .copy > *",{autoAlpha:0,y:16,duration:.7,ease:"power3.out",stagger:.18});
  tl.from("#s7phone",{autoAlpha:0,y:50,duration:.9,ease:"power3.out"},"-=0.5");
  tl.from("#s7 .stu",{autoAlpha:0,y:12,duration:.5},"+=0.2");
  tl.from("#paybtn",{autoAlpha:0,y:12,duration:.5},"+=0.4");
  tl.to("#paybtn",{scale:.96,duration:.12,yoyo:true,repeat:1},"+=0.5");
  tl.from("#receipt",{autoAlpha:0,y:34,duration:.7,ease:"power3.out"},"+=0.25");
  tl.to({},{duration:1.8}).to(...outAll("#s7")).to(...hideS("#s7"));

  /* S8 AI — bill rows parse, hindi line appears, NPS badge stamps */
  tl.to(...showS("#s8"));
  tl.from("#s8 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s8 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#ai1",{autoAlpha:0,y:40,duration:.8,ease:"power3.out"},"+=0.25");
  tl.from("#ai1 .billrow",{autoAlpha:0,x:-16,duration:.4,stagger:.35},"-=0.2");
  tl.from("#ai2",{autoAlpha:0,y:40,duration:.8,ease:"power3.out"},"-=0.6");
  tl.from("#hindi",{autoAlpha:0,duration:.7},"+=0.2");
  tl.from("#npsb",{autoAlpha:0,scale:2,duration:.5,ease:"power4.in"},"+=0.4");
  tl.from("#s8s",{autoAlpha:0,duration:.7},"+=0.3");
  tl.to({},{duration:1.7}).to(...outAll("#s8")).to(...hideS("#s8"));

  /* S9 research — counters run */
  const n={a:0,b:0,c:0};
  tl.to(...showS("#s9"));
  tl.from("#s9 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s9 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s9 .bn",{autoAlpha:0,y:34,duration:.7,ease:"power3.out",stagger:.22},"+=0.2");
  tl.to(n,{a:113,b:77,c:8,duration:2,ease:"power2.out",onUpdate(){
    $("#n1").textContent=Math.round(n.a);$("#n2").textContent=Math.round(n.b);$("#n3").textContent=Math.round(n.c);}},"-=0.3");
  tl.from("#s9s",{autoAlpha:0,duration:.8},"-=0.5");
  tl.to({},{duration:1.9}).to(...outAll("#s9")).to(...hideS("#s9"));

  /* S10 stack */
  tl.to(...showS("#s10"));
  tl.from("#s10 .k",{autoAlpha:0,y:10,duration:.5});
  tl.from("#s10 .med",{autoAlpha:0,y:16,duration:.8,ease:"power3.out"},"-=0.15");
  tl.from("#s10 .srw",{autoAlpha:0,x:-30,duration:.5,ease:"power3.out",stagger:.4},"+=0.25");
  tl.to({},{duration:2}).to(...outAll("#s10")).to(...hideS("#s10"));

  /* S11 end */
  tl.to(...showS("#s11"));
  tl.from("#s11 .endmark",{autoAlpha:0,y:26,duration:1,ease:"power3.out"});
  tl.from("#s11a",{autoAlpha:0,y:12,duration:.7},"-=0.3");
  tl.from("#s11b",{autoAlpha:0,y:12,duration:.7},"-=0.35");
  tl.from("#replayBtn",{autoAlpha:0,duration:.8},"+=0.3");

  function start(){ if(started)return; started=true;
    gsap.to("#poster",{autoAlpha:0,duration:.7,ease:"power2.inOut",onComplete(){$("#poster").style.visibility="hidden";}});
    gsap.to("#ctl",{opacity:1,duration:.6,delay:1});
    tl.play(0.001);}
  function replay(){$("#paused").style.display="none";tl.pause(0).play(0.001);}
  function togglePause(){ if(!started||tl.progress()===0)return;
    if(tl.paused()&&tl.progress()<0.999){tl.play();$("#paused").style.display="none";}
    else if(!tl.paused()){tl.pause();$("#paused").style.display="flex";}}
  function fullscreen(){const el=document.documentElement;
    if(!document.fullscreenElement){(el.requestFullscreen||el.webkitRequestFullscreen||function(){}).call(el);}
    else{(document.exitFullscreen||document.webkitExitFullscreen||function(){}).call(document);}}

  $("#playBtn").addEventListener("click",e=>{e.stopPropagation();start();});
  $("#replayBtn").addEventListener("click",e=>{e.stopPropagation();replay();});
  $("#stage").addEventListener("click",()=>togglePause());
  document.addEventListener("keydown",e=>{
    if(e.code==="Space"){e.preventDefault();started?togglePause():start();}
    if(e.key==="r"||e.key==="R"){if(started)replay();}
    if(e.key==="f"||e.key==="F"){fullscreen();}});

  const qp=new URLSearchParams(location.search);
  if(qp.has("autoplay")||qp.has("t")){start();
    if(qp.has("t")){const t=Math.max(0.02,parseFloat(qp.get("t"))||0.02);
      qp.has("play")?tl.play(t):tl.pause(t);}}
})();
</script>
</body>
</html>
