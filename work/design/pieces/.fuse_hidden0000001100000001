<script type="text/x-dc" data-dc-script data-props="{
  &quot;seriesTitle&quot;: {&quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;A Personal Piece of Earth&quot;, &quot;tsType&quot;: &quot;string&quot;},
  &quot;artistName&quot;: {&quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;Harsh Arya&quot;, &quot;tsType&quot;: &quot;string&quot;},
  &quot;year&quot;: {&quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;2020–2021&quot;, &quot;tsType&quot;: &quot;string&quot;},
  &quot;footerNote&quot;: {&quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;Magazine cut-outs, hand-arranged on a cutting mat and finished digitally. A study in scale, and in the surreal.&quot;, &quot;tsType&quot;: &quot;string&quot;}
}">
class Component extends DCLogic {
  componentDidMount() {
    this._cleanup = [];
    let tries = 0;
    const attempt = () => {
      if (this._wired) return;
      const n = document.querySelectorAll('[data-reveal]').length;
      if (n > 0) { this._wired = true; this.wireReveals(); return; }
      if (tries++ < 20) setTimeout(attempt, 50);
    };
    attempt();
  }
  componentWillUnmount() {
    (this._cleanup || []).forEach(fn => fn());
  }
  // ---- deterministic per-tile randomness ----
  _hash(str) {
    let h = 1779033703 ^ str.length;
    for (let i = 0; i < str.length; i++) {
      h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
      h = (h << 13) | (h >>> 19);
    }
    return () => {
      h = Math.imul(h ^ (h >>> 16), 2246822507);
      h = Math.imul(h ^ (h >>> 13), 3266489909);
      h ^= h >>> 16;
      return (h >>> 0) / 4294967296;
    };
  }

  buildTiles(fig) {
    const stage = fig.querySelector('[data-tiles]');
    if (!stage || stage._built) return;
    const seed = stage.querySelector('[data-finished]');
    const src = seed ? seed.getAttribute('src') : null;
    if (!src) return;
    const cols = 13, rows = 13;
    const rand = this._hash(src);
    const tiles = [];
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const t = document.createElement('div');
        const w = 100 / cols, h = 100 / rows;
        t.style.cssText =
          'position:absolute;' +
          'left:' + (c * w) + '%;top:' + (r * h) + '%;' +
          'width:calc(' + w + '% + 1px);height:calc(' + h + '% + 1px);' +
          'background-image:url("' + src + '");' +
          'background-size:' + (cols * 100) + '% ' + (rows * 100) + '%;' +
          'background-position:' + (c / (cols - 1)) * 100 + '% ' + (r / (rows - 1)) * 100 + '%;' +
          'will-change:transform,opacity;backface-visibility:hidden;';
        const cx = (c + 0.5) / cols - 0.5;
        const cy = (r + 0.5) / rows - 0.5;
        const ang = Math.atan2(cy, cx) + (rand() - 0.5) * 1.4;
        // disintegration sweeps roughly top -> bottom, with jitter
        const start = Math.max(0, Math.min(0.6, (cy + 0.5) * 0.4 + (rand() - 0.5) * 0.45));
        t._p = {
          dx: Math.cos(ang),
          dy: Math.sin(ang),
          dist: 0.10 + rand() * 0.30,   // fraction of stage diagonal, drift outward
          grav: 0.25 + rand() * 0.55,   // downward fall
          rot: (rand() - 0.5) * 90,
          start: start,
          span: 0.45 + rand() * 0.3
        };
        stage.appendChild(t);
        tiles.push(t);
      }
    }
    if (seed) seed.remove();
    stage._built = true;
    stage._tiles = tiles;
    this.applyReveal(fig, 0);
  }

  applyReveal(fig, p) {
    const stage = fig.querySelector('[data-tiles]');
    if (!stage || !stage._tiles) return;
    const rect = stage.getBoundingClientRect();
    const diag = Math.hypot(rect.width, rect.height) || 600;
    const easeOut = t => 1 - Math.pow(1 - t, 3);
    for (const t of stage._tiles) {
      const q = t._p;
      let lp = (p - q.start) / q.span;
      lp = lp < 0 ? 0 : lp > 1 ? 1 : lp;
      const e = easeOut(lp);
      const tx = q.dx * q.dist * diag * e;
      const ty = q.dy * q.dist * diag * e + q.grav * diag * e * e * 0.7;
      const rot = q.rot * e;
      const sc = 1 - 0.28 * e;
      t.style.transform = 'translate(' + tx.toFixed(1) + 'px,' + ty.toFixed(1) + 'px) rotate(' + rot.toFixed(1) + 'deg) scale(' + sc.toFixed(3) + ')';
      t.style.opacity = (1 - e).toFixed(3);
    }
  }

  wireReveals() {
    const figs = Array.from(document.querySelectorAll('[data-reveal]'));
    if (!figs.length) return;
    const canHover = window.matchMedia('(hover: hover)').matches;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const ease = t => t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

    figs.forEach(fig => this.buildTiles(fig));

    const animateTo = (fig, target) => {
      const mark = fig.querySelector('[data-reveal-mark]');
      if (mark) mark.style.transition = 'opacity .5s ease';
      if (mark) mark.style.opacity = target >= 0.5 ? '0.25' : '1';
      const from = (typeof fig._p === 'number') ? fig._p : 0;
      if (reduce) { fig._p = target; this.applyReveal(fig, target); return; }
      if (fig._raf) cancelAnimationFrame(fig._raf);
      const dur = 1250, t0 = performance.now();
      const tick = (now) => {
        const k = Math.min(1, (now - t0) / dur);
        const v = from + (target - from) * ease(k);
        fig._p = v;
        this.applyReveal(fig, v);
        if (k < 1) fig._raf = requestAnimationFrame(tick); else fig._raf = null;
      };
      fig._raf = requestAnimationFrame(tick);
    };

    figs.forEach(fig => {
      if (canHover) {
        const on = () => animateTo(fig, 1);
        const off = () => animateTo(fig, 0);
        fig.addEventListener('mouseenter', on);
        fig.addEventListener('mouseleave', off);
        this._cleanup.push(() => { fig.removeEventListener('mouseenter', on); fig.removeEventListener('mouseleave', off); });
      }
      let open = false;
      const toggle = () => { open = !open; animateTo(fig, open ? 1 : 0); };
      fig.addEventListener('click', toggle);
      this._cleanup.push(() => fig.removeEventListener('click', toggle));
    });

    if (!canHover) {
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => animateTo(e.target, e.intersectionRatio > 0.55 ? 1 : 0));
      }, { threshold: [0, 0.55, 1] });
      figs.forEach(f => io.observe(f));
      this._cleanup.push(() => io.disconnect());
    }

    const onResize = () => figs.forEach(f => this.applyReveal(f, (typeof f._p === 'number') ? f._p : 0));
    window.addEventListener('resize', onResize);
    this._cleanup.push(() => window.removeEventListener('resize', onResize));
  }
  renderVals() {
    const p = this.props || {};
    return {
      seriesTitle: p.seriesTitle ?? 'A Personal Piece of Earth',
      artistName: p.artistName ?? 'Harsh Arya',
      year: p.year ?? '2020–2021',
      footerNote: p.footerNote ?? 'Magazine cut-outs, hand-arranged on a cutting mat and finished digitally. A study in scale, and in the surreal.'
    };
  }
}
</script>
