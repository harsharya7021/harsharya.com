  <section data-screen-label="A personal piece of Earth" style="max-width:1180px;margin:0 auto;padding:clamp(110px,18vh,210px) clamp(20px,6vw,72px) 0;">
    <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.3em;text-transform:uppercase;color:#B0A899;text-align:center;margin-bottom:clamp(40px,7vh,72px);">Before any of this</div>
    <blockquote style="margin:0 auto;max-width:21ch;text-align:center;font-weight:300;font-size:clamp(28px,4.4vw,52px);line-height:1.22;letter-spacing:-0.012em;color:#1C1916;">
