.DS_Store
.vscode/
.idea/
node_modules/
*.log
# scratch files from the build pipeline
_tmp-*
**/_tmp-*
# archived superseded files (kept locally for reference, not in git)
_archive/
# exported media for the deck — local only, not part of the site
_deck-media/
# workshop: working notes, prototypes, draft markdown — local only
_workshop/
# AI working notes — .nojekyll publishes every committed file, so these must
# never be tracked or they become readable on the live site
CLAUDE.md
WORKING-WITH-HARSH.md
# contact-form backend: runs on a separate host, must never be served by the
# site (.nojekyll publishes every committed file), so it's kept out of git
_source/
# publish service: runs on the VPS, must never be served by the site — same
# reason as _source/. Deployed by scp/rsync from this folder, not via git.
_os/
# never track any env secrets, wherever they live
**/.env
test-harness.html
test-reveal.html
test-credrev.html
